{% extends "layout.njk" %}
{% block content %}
<section class="section">
  <div class="wrap">
    <h1 class="page-title">{{ L.venue.title | loc(locale) }}</h1>
    <div class="venue-grid">
      <div class="venue-info">
        <h2 class="section-title">{{ L.venue.where | loc(locale) }}</h2>
        <p class="venue-name">{{ venue.venueName }}</p>
        <p class="muted">{{ venue.address }}</p>
        {% if venue.room %}<p class="muted">{{ venue.room | loc(locale) }}</p>{% endif %}
        {% if venue.mapLink %}<p><a class="btn btn-ghost" href="{{ venue.mapLink }}">{{ L.venue.openMap | loc(locale) }} ↗</a></p>{% endif %}
      </div>
      {% if venue.mapEmbed %}<div class="venue-map"><iframe title="Map" src="{{ venue.mapEmbed }}" loading="lazy"></iframe></div>{% endif %}
    </div>

    {% set gt = venue["gettingThere_" + locale] or venue.gettingThere_en %}
    {% if gt %}
      <div class="section-block">
        <h2 class="section-title">{{ L.venue.gettingThere | loc(locale) }}</h2>
        <div class="prose">{{ gt | md | safe }}</div>
      </div>
    {% endif %}
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <h2 class="section-title">{{ L.venue.practical | loc(locale) }}</h2>
    {% if cats.length %}
      {% for c in cats %}
        <h3 class="practical-cat">{{ L.venue.categories[c.key] | loc(locale) }}</h3>
        <div class="cards">
          {% for it in c.items %}
            <article class="card">
              <h4 class="card-title">{% if it.url %}<a href="{{ it.url }}">{{ it.title }}</a>{% else %}{{ it.title }}{% endif %}</h4>
              {% if it.address %}<p class="muted card-address">{{ it.address }}</p>{% endif %}
              <div class="prose">{{ (it["body_" + locale] or it.body_en) | md | safe }}</div>
            </article>
          {% endfor %}
        </div>
      {% endfor %}
    {% else %}
      <p class="placeholder">{{ L.venue.empty | loc(locale) }}</p>
    {% endif %}
  </div>
</section>
{% endblock %}
