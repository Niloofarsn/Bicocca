---
layout: base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "/{{ locale }}/venue/index.html"
pageKey: venue
---
<section class="section">
  <div class="wrap">
    <h1 class="page-title">{{ i18n.venue.title | loc(locale) }}</h1>

    <div class="venue-grid">
      <div class="venue-info">
        <h2 class="section-title">{{ i18n.venue.where | loc(locale) }}</h2>
        <p class="venue-name">{{ venue.venueName }}</p>
        <p class="muted">{{ venue.address }}</p>
        {% if venue.room %}<p class="muted">{{ venue.room | loc(locale) }}</p>{% endif %}
        {% if venue.mapLink %}<p><a class="btn btn-ghost" href="{{ venue.mapLink }}">{{ i18n.venue.openMap | loc(locale) }} ↗</a></p>{% endif %}
      </div>
      {% if venue.mapEmbed %}
        <div class="venue-map">
          <iframe title="Map" src="{{ venue.mapEmbed }}" loading="lazy"></iframe>
        </div>
      {% endif %}
    </div>

    {% set gt = venue["gettingThere_" + locale] or venue.gettingThere_en %}
    {% if gt %}
      <div class="section-block">
        <h2 class="section-title">{{ i18n.venue.gettingThere | loc(locale) }}</h2>
        <div class="prose">{{ gt | md | safe }}</div>
      </div>
    {% endif %}
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <h2 class="section-title">{{ i18n.venue.practical | loc(locale) }}</h2>

    {% if collections.practical | length %}
      {% set cats = ["hotel", "dinner", "transport", "other"] %}
      {% for cat in cats %}
        {% set items = collections.practical | where("data.category", cat) %}
        {% if items | length %}
          <h3 class="practical-cat">{{ i18n.venue.categories[cat] | loc(locale) }}</h3>
          <div class="cards">
            {% for it in items %}
              <article class="card">
                <h4 class="card-title">
                  {% if it.data.url %}<a href="{{ it.data.url }}">{{ it.data.title }}</a>{% else %}{{ it.data.title }}{% endif %}
                </h4>
                {% if it.data.address %}<p class="muted card-address">{{ it.data.address }}</p>{% endif %}
                <div class="prose">{{ (it.data["body_" + locale] or it.data.body_en) | md | safe }}</div>
              </article>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}
    {% else %}
      <p class="placeholder">{{ i18n.venue.empty | loc(locale) }}</p>
    {% endif %}
  </div>
</section>
